				<attribute>Class</attribute>
				<value>HaremLeaderMeme.PreceptComp_UnwillingToDo_Gendered_LeaderExempt</value>
			</li>
		</operations>
	</Operation>

	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationTest">
				<xpath>Defs/PreceptDef[defName="SpouseCount_Female_MaxTwo"]</xpath>
			</li>
			<li Class="PatchOperationAttributeSet">
				<xpath>Defs/PreceptDef[defName="SpouseCount_Female_MaxTwo"]/comps/li[@Class="PreceptComp_UnwillingToDo_Gendered"]</xpath>
				<attribute>Class</attribute>
				<value>HaremLeaderMeme.PreceptComp_UnwillingToDo_Gendered_LeaderExempt</value>
			</li>
		</operations>
	</Operation>

	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationTest">
				<xpath>Defs/PreceptDef[defName="SpouseCount_Male_MaxThree"]</xpath>
			</li>
			<li Class="PatchOperationAttributeSet">
				<xpath>Defs/PreceptDef[defName="SpouseCount_Male_MaxThree"]/comps/li[@Class="PreceptComp_UnwillingToDo_Gendered"]</xpath>
